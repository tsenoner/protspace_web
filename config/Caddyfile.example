# Example Caddyfile for the protspace FASTA prep backend.
# REQUIRED: Caddy must be built with the `caddy-ratelimit` plugin
# (https://github.com/mholt/caddy-ratelimit).

(prep_backend) {
    @prepare_post {
        method POST
        path /api/prepare
    }
    request_body @prepare_post {
        max_size 9MB
    }
    rate_limit @prepare_post {
        zone prepare_submit {
            key {client_ip}
            events 5
            window 15m
        }
    }
    handle /api/prepare* {
        reverse_proxy {args[0]} {
            transport http {
                read_timeout 10m
                response_header_timeout 10m
            }
        }
    }
}

protspace.example.com {
    encode zstd gzip

    # Static frontend (existing site root) — adjust to your deployment.
    root * /srv/protspace
    file_server

    import prep_backend protspace-prep:8000
}
